PORT=8787

# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional — defaults to gemini-2.5-flash (multimodal: handles text + photo input)
GEMINI_MODEL=gemini-2.5-flash

# Optional — subscription checkout. Without STRIPE_SECRET_KEY, "Upgrade" on
# /pricing unlocks the tier client-side instead of redirecting to real checkout.
# Price IDs default in code (server/stripe.mjs); env vars override if set.
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID_REGULAR=
STRIPE_PRICE_ID_PRO=

# Daily blog automation (see marketing/RAILWAY_CRON_SETUP.md)
# BLOG_DATA_DIR: persistent volume path on the web service (e.g. /data) so
#   cron-published posts survive redeploys. Unset in local dev = uses repo file.
BLOG_DATA_DIR=
# BLOG_API_TOKEN: shared secret; the cron service authenticates to POST /api/blog.
#   Set the SAME value on the web service and the cron service.
BLOG_API_TOKEN=
# PUBLIC_BASE_URL: set on the cron service so it knows where to publish.
PUBLIC_BASE_URL=
