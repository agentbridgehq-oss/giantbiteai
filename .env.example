PORT=8787

# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Model slugs — verify current ids at https://openrouter.ai/models if a call fails
TEXT_MODEL=deepseek/deepseek-r1
VISION_MODEL=qwen/qwen2.5-vl-72b-instruct

# Shown in OpenRouter dashboards/rankings, not required
SITE_URL=http://localhost:5173
SITE_NAME=GiantBiteAI

# Optional — Pro subscription checkout. Without these, "Upgrade" on /pricing
# unlocks Pro free client-side instead of redirecting to a real checkout.
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID_MONTHLY=
STRIPE_PRICE_ID_YEARLY=
