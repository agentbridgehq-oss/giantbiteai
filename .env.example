PORT=8787

# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional — defaults to gemini-2.5-flash (multimodal: handles text + photo input)
GEMINI_MODEL=gemini-2.5-flash

# Optional — subscription checkout. Without these, "Upgrade" on /pricing
# unlocks the tier free client-side instead of redirecting to a real checkout.
STRIPE_SECRET_KEY=
# Monthly recurring price IDs (created in Stripe). Regular $12.99/mo, Pro $19.99/mo.
STRIPE_PRICE_ID_REGULAR=
STRIPE_PRICE_ID_PRO=
