PORT=8787

# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional — defaults to gemini-2.5-flash (multimodal: handles text + photo input)
GEMINI_MODEL=gemini-2.5-flash

# Optional — Pro subscription checkout. Without these, "Upgrade" on /pricing
# unlocks Pro free client-side instead of redirecting to a real checkout.
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID_MONTHLY=
STRIPE_PRICE_ID_YEARLY=
